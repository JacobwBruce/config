macos-icon=custom
macos-custom-icon=~/Documents/icons/ghostty_8.icns

# Themes
# ==================
# theme = "Material Design Colors"
# theme = "Ayu Mirage"
theme = "TokyoNight"
# theme = teide_darker
# theme = meowsoot


# Fonts
# ==================
font-size = 16
font-style = Medium
adjust-cell-height = 25%
# font-thicken = true
# font-style = SemiBold

# JetBrains
# font-family = JetBrainsMono Nerd Font

# Maple
# font-family = Maple Mono NF
# font-codepoint-map = U+E718=JetBrainsMono Nerd Font Mono
# font-feature=cv02, cv31

# Monaspace Neon
font-family = Monaspace Neon Var
font-feature=calt, ss01, ss02, ss03, ss04, ss05, ss06, ss07, ss08, ss09, liga

# Geist
# font-family=GeistMono Nerd Font
# font-codepoint-map = U+E718=JetBrainsMono Nerd Font Mono

# Background & Window Options
# ==================
background = #000000
background-opacity = 0.80
background-blur-radius = 24

macos-titlebar-style = hidden
window-decoration = true
window-padding-x = 10
window-padding-y = 10
window-padding-balance = true

cursor-style = block
cursor-style-blink = false

# Misc
# ==================
custom-shader = shaders/cursor_sweep.glsl
keybind = super+r=reload_config
shell-integration-features = no-cursor 
