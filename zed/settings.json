// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "relative_line_numbers": "enabled",
  "outline_panel": {
    "dock": "right",
  },
  "agent": {
    "dock": "left",
    "favorite_models": [],
    "model_parameters": [],
  },
  "vim_mode": true,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Dim Night",
  },
  "icon_theme": {
    "mode": "system",
    "light": "Flow Deep Light",
    "dark": "Flow Deep",
  },
  "cursor_shape": "bar",
  "experimental.theme_overrides": {
    "players": [
      {
        "cursor": "#ffffff",
        "selection": "#214265",
      },
    ],
  },

  // ─────────────────────────────────────────────────────────────
  // Fonts
  // ─────────────────────────────────────────────────────────────
  "ui_font_family": "Monaspace Neon Var",
  "buffer_font_features": {
    "calt": true,
    "liga": true,
    "ss01": true,
    "ss02": true,
    "ss03": true,
    "ss04": true,
    "ss05": true,
    "ss06": true,
    "ss07": true,
    "ss08": true,
    "ss09": true,
  },
  "ui_font_size": 16.0,
  "buffer_font_family": "Monaspace Neon Var",
  "buffer_font_size": 15.0,
  "buffer_font_weight": 500.0,
  "buffer_line_height": "comfortable",
  "agent_ui_font_size": 15,
  "agent_buffer_font_size": 15,

  // ─────────────────────────────────────────────────────────────
  // UI Panels & Layout
  // ─────────────────────────────────────────────────────────────
  "collaboration_panel": { "dock": "right" },
  "git_panel": { "dock": "right" },
  "project_panel": { "dock": "right" },
  "tab_bar": {
    "show": true,
    "show_tab_bar_buttons": false,
    "show_nav_history_buttons": false,
  },
  "preview_tabs": { "enabled": false },
  "max_tabs": 7,
  "title_bar": { "show_branch_name": true },
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false,
    "selections_menu": false,
  },
  "show_call_status_icon": false,

  // ─────────────────────────────────────────────────────────────
  // Editor Behavior
  // ─────────────────────────────────────────────────────────────
  "semantic_tokens": "combined",
  "base_keymap": "VSCode",
  "soft_wrap": "editor_width",
  "show_whitespaces": "trailing",
  "format_on_save": "on",
  "vertical_scroll_margin": 5,
  "hover_popover_delay": 150,

  // ─────────────────────────────────────────────────────────────
  // Diagnostics & Inlay Hints
  // ─────────────────────────────────────────────────────────────
  "diagnostics_max_severity": null,
  "diagnostics": {
    "inline": {
      "enabled": true,
      "max_severity": "warning",
      "padding": 4,
      "min_column": 0,
    },
  },
  "inlay_hints": {
    "enabled": true,
    "show_type_hints": false,
    "show_parameter_hints": true,
    "show_other_hints": true,
    "show_background": false,
    "edit_debounce_ms": 700,
    "scroll_debounce_ms": 50,
    "toggle_on_modifiers_press": null,
  },
}
